{
  "permissions": {
    "allow": [
      "Bash(bd create:*)",
      "Bash(bd update:*)",
      "Bash(export PATH=\"$HOME/.cargo/bin:$PATH\")",
      "Bash(cargo build:*)",
      "Bash(bd close:*)",
      "Bash(npx tsc:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [[ \"$f\" == *.rs || \"$f\" == */Cargo.toml ]] && touch \"$f\" || true; }",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
