# Copy to .env.testflight.local and fill in values from App Store Connect.
# Do not commit the real .env.testflight.local file.

ASC_KEY_ID=ABC123DEFG
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_PATH=/Users/gmecocci/.appstoreconnect/private_keys/AuthKey_ABC123DEFG.p8

# Optional. If omitted, the script keeps MARKETING_VERSION and increments build by 1.
# SKIM_VERSION=0.1.0
# SKIM_BUILD_NUMBER=2

# Optional. true means the uploaded build can only be used for internal TestFlight.
TESTFLIGHT_INTERNAL_ONLY=false
